# ── SMARTUR Mobile — Variables de entorno ───────────────────────────────────
# Copia este archivo a ".env" y rellena los valores reales.
# Este archivo se pasa a Flutter en tiempo de build con --dart-define-from-file=.env

# URL base del API backend (sin trailing slash)
API_BASE_URL=http://TU_IP_O_DOMINIO:4000/api/v2

# URL del motor de recomendaciones ML
AI_ENGINE_URL=http://TU_IP_O_DOMINIO:8000

# URL del API para entorno de desarrollo (puede ser igual a API_BASE_URL)
API_BASE_URL_DEV=http://10.0.2.2:4000/api/v2

# Google Sign-In — Web Client ID (tipo 3, obtenido de Firebase Console)
# Firebase Console → Project Settings → Your apps → Web app → Client ID
GOOGLE_SERVER_CLIENT_ID=TU_WEB_CLIENT_ID.apps.googleusercontent.com

# OpenWeather API Key — para el widget del clima (opcional)
# Obtener en: https://openweathermap.org/api → "Current Weather Data"
# Si se deja vacío, el widget del clima se oculta automáticamente
OPENWEATHER_API_KEY=
